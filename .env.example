# Environment variables for WH ED Mentorship App
# Copy this to .env.local and fill in your values

# Database connection (Neon/Supabase PostgreSQL)
# Format: postgresql://postgres:PASSWORD@host:port/dbname
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.thdqhdwrqvfbcionacpt.supabase.co:5432/postgres

# JWT secret - generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-minimum-32-characters

# App URL (for production)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
